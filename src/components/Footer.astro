---
const year = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-100 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="font-bold text-gray-900 text-lg hover:text-brand-600 transition-colors">
          <span translate="no">FuyouAI</span> Blog
        </a>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">
          Practical insights on using AI to think more clearly, make better decisions, and turn ideas into action.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Navigation</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-gray-500 hover:text-brand-600 transition-colors">Home</a></li>
          <li><a href="/blog/" class="text-sm text-gray-500 hover:text-brand-600 transition-colors">Blog</a></li>
          <li><a href="/about/" class="text-sm text-gray-500 hover:text-brand-600 transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Product</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="https://fuyouai.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-brand-600 hover:text-brand-700 font-medium transition-colors"
            >
              Try <span translate="no">FuyouAI</span> →
            </a>
          </li>
          <li>
            <a href="/rss.xml" class="text-sm text-gray-500 hover:text-brand-600 transition-colors">
              RSS Feed
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-400">
        © {year} <span translate="no">FuyouAI</span>. All rights reserved.
      </p>
      <p class="text-xs text-gray-400">
        Turn vague ideas into clear action plans at{' '}
        <a href="https://fuyouai.com" target="_blank" rel="noopener noreferrer" class="text-brand-500 hover:text-brand-600">
          fuyouai.com
        </a>
      </p>
    </div>
  </div>
</footer>
