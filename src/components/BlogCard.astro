---
export interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category?: string;
  tags?: string[];
}

const { title, description, slug, pubDate, category, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-gray-100 rounded-xl p-6 hover:border-brand-200 hover:shadow-md transition-all duration-200 bg-white">
  <div class="flex items-center gap-2 mb-3">
    {category && (
      <span class="text-xs font-medium text-brand-600 bg-brand-50 px-2.5 py-1 rounded-full">
        {category}
      </span>
    )}
    <time datetime={pubDate.toISOString()} class="text-xs text-gray-400">
      {formattedDate}
    </time>
  </div>

  <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-brand-600 transition-colors leading-snug">
    <a href={`/blog/${slug}/`} class="hover:underline">
      {title}
    </a>
  </h2>

  <p class="text-sm text-gray-500 leading-relaxed mb-4 line-clamp-3">
    {description}
  </p>

  <div class="flex items-center justify-between">
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs text-gray-400 bg-gray-50 px-2 py-0.5 rounded">
            #{tag}
          </span>
        ))}
      </div>
    )}
    <a
      href={`/blog/${slug}/`}
      class="text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors ml-auto"
    >
      Read more →
    </a>
  </div>
</article>
